# ============================================
# Configurações da Unico Sign API
# ============================================

# URL base da API da Unico
UNICO_API_URL=https://api.unicosign.com.br

# URL de autenticação OAuth2
UNICO_AUTH_URL=https://identity.acesso.io/oauth2/token

# Credenciais da Unico (pegar no painel da Unico)
UNICO_TENANT_ID=seu_tenant_id_aqui
UNICO_ISSUER=seu_issuer_aqui

# Caminho da chave privada (relativo ao diretório /unico/)
UNICO_PRIVATE_KEY_PATH=private-key.pem

# Dados do emissor (quem assina/envia os documentos)
UNICO_EMITTER_NAME=Nome da Empresa
UNICO_EMITTER_EMAIL=email@empresa.com
UNICO_EMITTER_UUID=uuid_do_emissor_aqui

# ============================================
# URL do Webhook (IMPORTANTE PARA RAILWAY!)
# ============================================
# No Railway, configure com a URL pública do seu projeto:
# Exemplo: UNICO_WEBHOOK_URL=https://seu-projeto.up.railway.app/api/unico-webhook.php
UNICO_WEBHOOK_URL=https://SEU_DOMINIO/api/unico-webhook.php

# Cache do token OAuth da Unico (gerenciado automaticamente pela API)
UNICO_ACCESS_TOKEN=
UNICO_ACCESS_TOKEN_EXPIRES_AT=0
# Caminho opcional para cache em arquivo (fora de /api e oculto)
UNICO_ACCESS_TOKEN_CACHE_FILE=storage/.secrets/.unico_access_token.json

# ============================================
# Banco de Dados SQL Server
# ============================================
DB_SERVER=servidor.database.windows.net
DB_DATABASE=nome_do_banco
DB_USER=usuario
DB_PASSWORD=senha_segura_aqui

# Webhook shared secret (Unico) � exija via header X-Webhook-Secret
UNICO_WEBHOOK_SECRET=mude-este-segredo
